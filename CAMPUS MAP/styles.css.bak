/* ===== CSS VARIABLES ===== */
:root {
    /* Light Theme - Main color #e7f7fe and close colors */
    --main-color: #e7f7fe;
    --main-color-darker: #c5e8f5;
    --main-color-darkest: #9ed5ed;
    --accent-blue: #5eb7e0;
    --accent-teal: #4db6ac;
    --accent-cyan: #00bcd4;

    /* Primary accent */
    --primary: #3498db;
    --primary-light: #5dade2;
    --primary-dark: #2980b9;
    --primary-glow: rgba(52, 152, 219, 0.3);

    /* Route path - Red */
    --route-color: #ff0000;
    --route-glow: rgba(255, 0, 0, 0.6);

    /* Buildings - Blue */
    --building-color: #3498db;
    --building-glow: rgba(52, 152, 219, 0.5);

    /* Markers */
    --start-color: #ff6600;
    /* Orange for Start */
    --start-glow: rgba(255, 102, 0, 0.5);
    --end-color: #f1c40f;
    /* Yellow for Destination */
    --end-glow: rgba(241, 196, 15, 0.5);

    /* UI Colors */
    --danger: #e74c3c;
    --warning: #f39c12;
    --success: #27ae60;

    /* Light Theme */
    --bg-primary: #e7f7fe;
    --bg-secondary: #ffffff;
    --bg-tertiary: #f5fbfe;
    --bg-elevated: #ffffff;

    --surface-1: rgba(255, 255, 255, 0.8);
    --surface-2: rgba(255, 255, 255, 0.95);
    --surface-glass: rgba(255, 255, 255, 0.5);

    --text-primary: #1a3a4a;
    --text-secondary: #4a6572;
    --text-muted: #7a9aa8;

    --border-color: #fff;
    --border-subtle: rgba(52, 152, 219, 0.15);
    --border-medium: rgba(52, 152, 219, 0.25);

    /* Pill container styling - from reference */
    --pill-bg: rgba(255, 255, 255, 0.5);
    --pill-blur: blur(10px);

    /* Shadows */
    --shadow-sm: 0 2px 8px rgba(52, 152, 219, 0.1);
    --shadow-md: 0 4px 20px rgba(52, 152, 219, 0.15);
    --shadow-lg: 0 8px 40px rgba(52, 152, 219, 0.2);
    --shadow-glow: 0 0 30px var(--primary-glow);

    /* Spacing */
    --space-xs: 0.25rem;
    --space-sm: 0.5rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2rem;
    --space-2xl: 3rem;

    /* Border Radius */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-xl: 28px;
    --radius-pill: 50px;
    --radius-full: 9999px;

    /* Transitions */
    --transition-fast: 150ms ease;
    --transition-base: 250ms ease;
    --transition-slow: 400ms ease;

    /* Typography */
    --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-size-xs: 0.75rem;
    --font-size-sm: 0.875rem;
    --font-size-base: 1rem;
    --font-size-lg: 1.125rem;
    --font-size-xl: 1.25rem;
    --font-size-2xl: 1.5rem;
    --font-size-3xl: 2rem;
}

/* ===== DARK MODE - Following reference style ===== */
body.dark-mode {
    --main-color: #000000;
    --main-color-darker: #1a1a1a;
    --main-color-darkest: #2a2a2a;

    --bg-primary: #000000;
    --bg-secondary: #1f1f1f;
    --bg-tertiary: #2a2a2a;
    --bg-elevated: #3b3b3b;

    --surface-1: rgba(59, 59, 59, 0.6);
    --surface-2: rgba(59, 59, 59, 0.8);
    --surface-glass: rgba(26, 26, 26, 0.5);

    --text-primary: #ffffff;
    --text-secondary: #cccccc;
    --text-muted: #aaaaaa;

    --border-color: #ffffff;
    --border-subtle: rgba(255, 255, 255, 0.2);
    --border-medium: rgba(255, 255, 255, 0.3);

    /* Pill container styling - from reference (dark) */
    --pill-bg: rgba(26, 26, 26, 0.5);
    --pill-blur: blur(10px);

    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.5);
}

/* ===== RESET & BASE ===== */
*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    font-size: 16px;
    scroll-behavior: smooth;
}

body {
    font-family: var(--font-family);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
    overflow: hidden;
    transition: background-color var(--transition-base), color var(--transition-base);
}

/* Make text labels clickable - cursor is set by JavaScript only for building-matched text */
svg text,
svg tspan {
    pointer-events: all !important;
}

/* ===== MAIN LAYOUT ===== */
.app-container {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
}

/* ===== TOP CONTROL BAR - Pill Shaped with Translucent Blur ===== */
.top-control-bar {
    position: fixed;
    top: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 6px 8px;
    /* Translucent blur effect from reference */
    background-color: var(--pill-bg);
    backdrop-filter: var(--pill-blur);
    -webkit-backdrop-filter: var(--pill-blur);
    border: 1px solid var(--border-color);
    border-radius: 50px;
    box-shadow: var(--shadow-lg);
    /* Fit content - no extra spacing */
    width: auto;
    max-width: 98%;
    transition: all var(--transition-base);
}

.top-control-bar:hover {
    box-shadow: var(--shadow-lg), 0 0 30px rgba(52, 152, 219, 0.1);
}

/* ===== MOBILE BOTTOM BAR - Same style as top bar ===== */
.mobile-bottom-bar {
    position: fixed;
    bottom: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    /* Always visible now */
    align-items: center;
    gap: var(--space-xs);
    padding: 6px 8px;
    /* Same translucent blur effect as top bar */
    background-color: var(--pill-bg);
    backdrop-filter: var(--pill-blur);
    -webkit-backdrop-filter: var(--pill-blur);
    border: 1px solid var(--border-color);
    border-radius: 50px;
    box-shadow: var(--shadow-lg);
    /* Fit content - match top bar */
    width: auto;
    max-width: 98%;
    transition: all var(--transition-base);
}

.mobile-bottom-bar:hover {
    box-shadow: var(--shadow-lg), 0 0 30px rgba(52, 152, 219, 0.1);
}

/* When Ask FUTIAN button is in the bottom bar */
.mobile-bottom-bar .control-btn.primary {
    padding: var(--space-sm) var(--space-md);
}

.mobile-bottom-bar .control-btn.primary span {
    display: inline;
    /* Always show text in bottom bar */
}

/* Hide "FUTIAN" part at 279px and below */
.mobile-bottom-bar .control-btn.primary .futian-text {
    display: inline;
}

@media (max-width: 279px) {
    .mobile-bottom-bar .control-btn.primary .futian-text {
        display: none;
    }
}

.bottom-bar-content {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
}

.bottom-bar-tip {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
    font-weight: 500;
    max-width: 200px;
    line-height: 1.3;
    text-align: left;
    display: none;
    /* Limit to 2 lines only */
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Show tip only when there's enough space (wider screens) */
@media (min-width: 550px) {
    .bottom-bar-tip {
        display: -webkit-box;
    }
}

.small-btn {
    padding: 6px 12px;
    font-size: var(--font-size-xs);
    height: 32px;
    white-space: nowrap;
}

.small-btn svg {
    width: 14px;
    height: 14px;
}

/* Logo in top bar */
.logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-right: var(--space-md);
    border-right: 1px solid var(--border-subtle);
    margin-right: var(--space-xs);
}

.logo-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(52, 152, 219, 0.4));
    transition: var(--transition-base);
}

.logo:hover .logo-icon {
    filter: drop-shadow(0 0 12px rgba(52, 152, 219, 0.6));
    transform: scale(1.05);
}

.logo-text {
    display: flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
}

/* FUTIA Brand Text - Dark in Light Mode, White in Dark Mode */
.brand-futia {
    font-size: var(--font-size-lg);
    font-weight: 800;
    letter-spacing: 1px;
    color: #1a1a1a;
    text-transform: uppercase;
    transition: color var(--transition-base);
}

/* Campus Navigator Text - Always Gradient */
.brand-campus {
    font-size: var(--font-size-base);
    font-weight: 600;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Dark Mode - FUTIA becomes white */
body.dark-mode .brand-futia {
    color: #ffffff;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
}

/* ===== DROPDOWN SELECT STYLING ===== */
.control-select-wrapper {
    position: relative;
    min-width: 160px;
}

.control-select {
    width: 100%;
    padding: var(--space-sm) var(--space-lg);
    padding-right: 36px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    color: var(--text-primary);
    font-family: inherit;
    font-size: var(--font-size-sm);
    cursor: pointer;
    appearance: none;
    transition: var(--transition-base);
}

.control-select:hover {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-glow);
}

.control-select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px var(--primary-glow);
}

/* Dropdown options styling - Native select styling */
.control-select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
    padding: 14px 18px;
    font-size: var(--font-size-sm);
    font-weight: 400;
    line-height: 1.5;
    border: none;
    min-height: 40px;
}

.control-select option:first-child {
    color: var(--text-muted);
    font-style: italic;
}

.control-select option:hover {
    background: var(--main-color-darker);
    color: var(--text-primary);
}

.control-select option:checked,
.control-select option:focus {
    background: linear-gradient(0deg, var(--primary) 0%, var(--primary) 100%);
    background-color: var(--primary) !important;
    color: white;
    font-weight: 500;
}

/* Dark mode dropdown styling */
body.dark-mode .control-select {
    background-color: rgba(26, 26, 26, 0.9);
    border-color: #fff;
    color: #fff;
}

body.dark-mode .control-select option {
    background-color: #1a1a1a;
    color: #eee;
    padding: 14px 18px;
}

body.dark-mode .control-select option:first-child {
    color: #888;
}

body.dark-mode .control-select option:hover {
    background-color: #2a2a2a;
}

body.dark-mode .control-select option:checked,
body.dark-mode .control-select option:focus {
    background-color: #3b3b3b !important;
    color: #fff;
    font-weight: 500;
}

.select-arrow {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    pointer-events: none;
}

/* ===== LOCATION SELECTOR BUTTONS (Modal Trigger) ===== */
.location-selector-btn {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    color: var(--text-primary);
    font-family: inherit;
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: var(--transition-base);
    min-width: 160px;
}

.location-selector-btn:hover {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-glow);
}

.location-selector-btn .selector-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
}

.location-selector-btn .selector-icon.start {
    color: var(--start-color);
}

.location-selector-btn .selector-icon.end {
    color: var(--end-color);
}

.location-selector-btn span {
    flex: 1;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.location-selector-btn .chevron-icon {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    flex-shrink: 0;
}

body.dark-mode .location-selector-btn {
    background-color: rgba(26, 26, 26, 0.9);
    border-color: #fff;
    color: #fff;
}

/* ===== LOCATION SELECTION MODAL ===== */
.location-modal {
    position: fixed;
    inset: 0;
    z-index: 1001;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-base);
}

.location-modal.active {
    opacity: 1;
    visibility: visible;
}

.location-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
}

.location-modal-container {
    position: relative;
    width: 90%;
    max-width: 400px;
    max-height: 70vh;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    transform: translateY(20px) scale(0.95);
    transition: var(--transition-base);
    overflow: hidden;
}

.location-modal.active .location-modal-container {
    transform: translateY(0) scale(1);
}

.location-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--border-subtle);
}

.location-modal-header h2 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin: 0;
}

.modal-close-btn {
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-color);
    background: var(--surface-1);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
}

.modal-close-btn svg {
    width: 18px;
    height: 18px;
}

.modal-close-btn:hover {
    background: var(--danger);
    color: white;
    border-color: var(--danger);
}

.location-modal-body {
    padding: var(--space-md);
    overflow-y: auto;
    flex: 1;
}

.location-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
}

.location-item {
    display: block;
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: inherit;
    font-size: var(--font-size-base);
    text-align: left;
    cursor: pointer;
    transition: var(--transition-base);
}

.location-item:hover {
    background: var(--main-color-darker);
    border-color: var(--border-subtle);
}

.location-item.selected {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
}

body.dark-mode .location-item:hover {
    background: rgba(255, 255, 255, 0.1);
}

body.dark-mode .location-item.selected {
    background: var(--primary);
}

/* ===== CONTROL BUTTONS ===== */
.control-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    font-family: inherit;
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-base);
    white-space: nowrap;
}

.control-btn svg {
    width: 18px;
    height: 18px;
}

.control-btn.primary {
    background: var(--gradient-primary);
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border-color: var(--primary);
    box-shadow: var(--shadow-md), 0 0 20px var(--primary-glow);
}

.control-btn.primary:hover {
    filter: brightness(1.15);
    box-shadow: var(--shadow-lg), 0 0 30px var(--primary-glow);
}

.control-btn.secondary {
    background: var(--surface-glass);
    backdrop-filter: blur(5px);
    color: var(--text-secondary);
}

.control-btn.secondary:hover {
    background: var(--surface-2);
    color: var(--text-primary);
    filter: brightness(1.1);
}

/* Swap button */
.swap-btn {
    width: 36px;
    height: 36px;
    min-width: 36px;
    padding: 0;
    border: 2px dashed var(--border-medium);
    background: transparent;
    border-radius: var(--radius-full);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
}

.swap-btn svg {
    width: 18px;
    height: 18px;
}

.swap-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--surface-1);
    transform: rotate(180deg);
}

/* Dark mode toggle */
.dark-mode-btn {
    width: 40px;
    height: 40px;
    min-width: 40px;
    padding: 0;
    border: 1px solid var(--border-color);
    background: #1a1a1a;
    border-radius: var(--radius-full);
    color: #ffd700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
    box-shadow: var(--shadow-sm);
}

.dark-mode-btn svg {
    width: 20px;
    height: 20px;
}

.dark-mode-btn:hover {
    filter: brightness(1.2);
    box-shadow: var(--shadow-md);
}

body.dark-mode .dark-mode-btn {
    background: #ffeaa7;
    color: #1a1a1a;
    border-color: #ffeaa7;
}

/* Help button */
.help-btn {
    width: 40px;
    height: 40px;
    min-width: 40px;
    padding: 0;
    border: 1px solid var(--border-color);
    background: var(--surface-glass);
    backdrop-filter: blur(5px);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
}

.help-btn svg {
    width: 20px;
    height: 20px;
}

.help-btn:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
    filter: brightness(1.1);
}

/* ===== MAP SECTION ===== */
/* Map extends UNDER the top and bottom bars so blur effect shows when zooming */
.map-section {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    background:
        radial-gradient(ellipse at 20% 30%, rgba(52, 152, 219, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(77, 182, 172, 0.08) 0%, transparent 50%),
        var(--bg-primary);
    /* No padding - map goes edge to edge, under the bars */
    padding: 0;
    z-index: 1;
}

.map-wrapper {
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Center the default view with some visual padding */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 20px 100px 20px;
}

.map-container {
    width: 100%;
    height: 100%;
    cursor: grab;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Allow content to overflow and go under the bars */
    overflow: visible;
    /* Touch support - prevent browser default touch behaviors */
    touch-action: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    /* Prevent callout on long press (iOS) */
    -webkit-touch-callout: none;
}

.map-container.grabbing {
    cursor: grabbing;
}

.map-container svg {
    max-width: 100%;
    max-height: 100%;
    /* Origin at top-left for correct zoom-to-point math */
    transform-origin: 0 0;
    transition: transform 0.1s ease-out;
}

/* Disable transition during active touch gestures for instant feedback */
.map-container.touch-active svg {
    transition: none;
}

/* Map Loading State */
.map-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    color: var(--text-muted);
}

.loading-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--border-subtle);
    border-top-color: var(--primary);
    border-radius: var(--radius-full);
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

/* ===== ZOOM CONTROLS ===== */
/* ===== ZOOM CONTROLS ===== */
.zoom-controls {
    position: absolute;
    bottom: 120px;
    right: 24px;
    /* Fixed spacing */
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Ensure horizontal centering */
    gap: 8px;
    /* Consistent gap */
    background: var(--pill-bg);
    backdrop-filter: var(--pill-blur);
    -webkit-backdrop-filter: var(--pill-blur);
    border: 1px solid var(--border-color);
    border-radius: 26px;
    /* Pill shape radius (44/2 + padding) */
    padding: 6px;
    /* Balanced padding */
    box-shadow: var(--shadow-lg);
}

.zoom-btn {
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    border-radius: 50%;
    /* Circular buttons look better in vertical pill */
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
    padding: 0;
    margin: 0;
}

.zoom-btn svg {
    width: 22px;
    height: 22px;
}

.zoom-btn:hover {
    background: var(--surface-2);
    color: var(--primary);
}

.zoom-btn:active {
    transform: scale(0.95);
}

.zoom-divider {
    width: 24px;
    /* Match icon visual width */
    height: 1px;
    background: var(--border-subtle);
    margin: 2px 0;
    /* Minimal vertical margin, gap handles the rest */
    flex-shrink: 0;
}

/* When dark-mode-btn and help-btn are moved to zoom-controls */
.zoom-controls .dark-mode-btn,
.zoom-controls .help-btn {
    width: 44px !important;
    height: 44px !important;
    min-width: 44px !important;
    min-height: 44px !important;
    max-width: 44px !important;
    max-height: 44px !important;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    background: transparent !important;
    color: var(--text-secondary) !important;
    border-radius: 50% !important;
    cursor: pointer;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: var(--transition-base);
}

.zoom-controls .dark-mode-btn:hover,
.zoom-controls .help-btn:hover {
    background: var(--surface-2) !important;
    color: var(--primary) !important;
}

.zoom-controls .dark-mode-btn:active,
.zoom-controls .help-btn:active {
    transform: scale(0.95);
}

.zoom-controls .dark-mode-btn svg,
.zoom-controls .help-btn svg {
    width: 22px !important;
    height: 22px !important;
}

/* ===== ZOOM CONTROLS HIDE/SHOW TOGGLE ===== */
/* Hide button styling */
.zoom-toggle-btn {
    position: relative;
}

.zoom-toggle-btn:hover {
    color: var(--danger) !important;
    background: rgba(231, 76, 60, 0.15) !important;
}

/* Zoom controls hidden state */
.zoom-controls.hidden {
    transform: translateX(calc(100% + 30px));
    opacity: 0;
    pointer-events: none;
}

/* Zoom controls transition for hiding/showing */
.zoom-controls {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease,
        all var(--transition-base);
}

/* Show Controls Tab - Appears on right edge when controls are hidden */
.zoom-show-tab {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%) translateX(100%);
    z-index: 90;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px 8px;
    background: var(--pill-bg);
    backdrop-filter: var(--pill-blur);
    -webkit-backdrop-filter: var(--pill-blur);
    border: 1px solid var(--border-color);
    border-right: none;
    border-radius: 12px 0 0 12px;
    color: var(--text-secondary);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease,
        background 0.2s ease,
        color 0.2s ease;
    box-shadow: -4px 0 15px rgba(0, 0, 0, 0.1);
    writing-mode: vertical-rl;
    text-orientation: mixed;
}

.zoom-show-tab svg {
    width: 18px;
    height: 18px;
}

.zoom-show-tab span {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.zoom-show-tab:hover {
    background: var(--surface-2);
    color: var(--primary);
    transform: translateY(-50%) translateX(0);
    box-shadow: -4px 0 20px var(--primary-glow);
}

.zoom-show-tab:active {
    transform: translateY(-50%) translateX(2px) scale(0.98);
}

/* When zoom controls are hidden, show the tab */
.zoom-show-tab.visible {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
    pointer-events: auto;
}

/* Pulse animation for the show tab to attract attention */
@keyframes pulseTab {

    0%,
    100% {
        box-shadow: -4px 0 15px rgba(0, 0, 0, 0.1);
    }

    50% {
        box-shadow: -4px 0 25px var(--primary-glow);
    }
}

.zoom-show-tab.visible {
    animation: pulseTab 2s ease-in-out infinite;
}

.zoom-show-tab.visible:hover {
    animation: none;
}

/* ===== RESPONSIVE ZOOM CONTROLS ===== */
/* At 480px - First reduction */
@media (max-width: 480px) {
    .zoom-controls {
        bottom: 100px;
        right: 16px;
        padding: 5px;
        gap: 6px;
        border-radius: 22px;
    }

    .zoom-btn {
        width: 38px;
        height: 38px;
    }

    .zoom-btn svg {
        width: 18px;
        height: 18px;
    }

    .zoom-divider {
        width: 20px;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 38px !important;
        height: 38px !important;
        min-width: 38px !important;
        min-height: 38px !important;
        max-width: 38px !important;
        max-height: 38px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 18px !important;
        height: 18px !important;
    }

    /* Show tab responsive */
    .zoom-show-tab {
        padding: 10px 6px;
        gap: 4px;
    }

    .zoom-show-tab svg {
        width: 14px;
        height: 14px;
    }

    .zoom-show-tab span {
        font-size: 9px;
    }
}

/* At 409px - Second reduction for very small screens */
@media (max-width: 409px) {
    .zoom-controls {
        bottom: 90px;
        right: 12px;
        padding: 4px;
        gap: 5px;
        border-radius: 20px;
    }

    .zoom-btn {
        width: 34px;
        height: 34px;
    }

    .zoom-btn svg {
        width: 16px;
        height: 16px;
    }

    .zoom-divider {
        width: 18px;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 34px !important;
        height: 34px !important;
        min-width: 34px !important;
        min-height: 34px !important;
        max-width: 34px !important;
        max-height: 34px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 16px !important;
        height: 16px !important;
    }

    /* Show tab responsive */
    .zoom-show-tab {
        padding: 8px 5px;
        gap: 3px;
    }

    .zoom-show-tab svg {
        width: 12px;
        height: 12px;
    }

    .zoom-show-tab span {
        font-size: 8px;
    }
}

/* At 311px - Third reduction for ultra small screens */
@media (max-width: 311px) {
    .zoom-controls {
        bottom: 80px;
        right: 8px;
        padding: 3px;
        gap: 4px;
        border-radius: 18px;
    }

    .zoom-btn {
        width: 30px;
        height: 30px;
    }

    .zoom-btn svg {
        width: 14px;
        height: 14px;
    }

    .zoom-divider {
        width: 16px;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 30px !important;
        height: 30px !important;
        min-width: 30px !important;
        min-height: 30px !important;
        max-width: 30px !important;
        max-height: 30px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 14px !important;
        height: 14px !important;
    }

    /* Show tab responsive - icon only on ultra small screens */
    .zoom-show-tab {
        padding: 6px 4px;
        gap: 0;
    }

    .zoom-show-tab svg {
        width: 14px;
        height: 14px;
    }

    .zoom-show-tab span {
        display: none;
    }
}

/* ===== ZOOM CONTROLS - HEIGHT BASED ADJUSTMENTS ===== */
/* Prevent zoom controls from interfering with top bar on short screens */

/* Short screens (height <= 600px) - Push zoom controls down */
@media (max-height: 600px) {
    .zoom-controls {
        /* Position from top instead of bottom to avoid top bar */
        top: 140px;
        bottom: auto;
    }
}

/* Very short screens (height <= 500px) - Compact + positioned safely */
@media (max-height: 500px) {
    .zoom-controls {
        top: 95px;
        padding: 4px;
        gap: 4px;
        border-radius: 18px;
    }

    .zoom-btn {
        width: 32px;
        height: 32px;
    }

    .zoom-btn svg {
        width: 16px;
        height: 16px;
    }

    .zoom-divider {
        width: 18px;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 32px !important;
        height: 32px !important;
        min-width: 32px !important;
        min-height: 32px !important;
        max-width: 32px !important;
        max-height: 32px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 16px !important;
        height: 16px !important;
    }
}

/* Ultra short screens (height <= 400px) - Minimal size */
@media (max-height: 400px) {
    .zoom-controls {
        top: 85px;
        padding: 3px;
        gap: 3px;
        border-radius: 16px;
    }

    .zoom-btn {
        width: 28px;
        height: 28px;
    }

    .zoom-btn svg {
        width: 14px;
        height: 14px;
    }

    .zoom-divider {
        width: 14px;
        margin: 1px 0;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 28px !important;
        height: 28px !important;
        min-width: 28px !important;
        min-height: 28px !important;
        max-width: 28px !important;
        max-height: 28px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 14px !important;
        height: 14px !important;
    }
}

/* Combined: Small width + short height (mobile landscape) */
@media (max-width: 600px) and (max-height: 450px) {
    .zoom-controls {
        top: 90px;
        right: 10px;
        padding: 3px;
        gap: 3px;
        border-radius: 14px;
    }

    .zoom-btn {
        width: 26px;
        height: 26px;
    }

    .zoom-btn svg {
        width: 12px;
        height: 12px;
    }

    .zoom-divider {
        width: 12px;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 26px !important;
        height: 26px !important;
        min-width: 26px !important;
        min-height: 26px !important;
        max-width: 26px !important;
        max-height: 26px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 12px !important;
        height: 12px !important;
    }
}

/* Extreme case: Very narrow + very short (small phone landscape) */
@media (max-width: 480px) and (max-height: 350px) {
    .zoom-controls {
        top: 80px;
        right: 8px;
        padding: 2px;
        gap: 2px;
        border-radius: 12px;
    }

    .zoom-btn {
        width: 24px;
        height: 24px;
    }

    .zoom-btn svg {
        width: 11px;
        height: 11px;
    }

    .zoom-divider {
        width: 10px;
        height: 1px;
    }

    .zoom-controls .dark-mode-btn,
    .zoom-controls .help-btn {
        width: 24px !important;
        height: 24px !important;
        min-width: 24px !important;
        min-height: 24px !important;
        max-width: 24px !important;
        max-height: 24px !important;
    }

    .zoom-controls .dark-mode-btn svg,
    .zoom-controls .help-btn svg {
        width: 11px !important;
        height: 11px !important;
    }
}

/* ===== BOTTOM INFO BAR - Pill Shaped with Translucent Blur ===== */
.bottom-info-bar {
    position: fixed;
    bottom: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: var(--space-xl);
    padding: var(--space-md) var(--space-2xl);
    /* Translucent blur effect from reference */
    background-color: var(--pill-bg);
    backdrop-filter: var(--pill-blur);
    -webkit-backdrop-filter: var(--pill-blur);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    /* Wider pill container - matching top bar */
    min-width: 80%;
    max-width: 98%;
    transition: all var(--transition-base);
}

.bottom-info-bar:hover {
    box-shadow: var(--shadow-lg), 0 0 30px rgba(52, 152, 219, 0.1);
}

/* Legend Section */
.legend {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-right: var(--space-lg);
    border-right: 1px solid var(--border-subtle);
}

.legend-title {
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.legend-items {
    display: flex;
    gap: var(--space-lg);
}

.legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
    white-space: nowrap;
}

.legend-marker {
    display: flex;
    align-items: center;
    justify-content: center;
}

.legend-marker svg {
    width: 20px;
    height: 20px;
}

.legend-marker.legend-start svg {
    color: var(--start-color);
    filter: drop-shadow(0 0 4px var(--start-glow));
}

.legend-marker.legend-end svg {
    color: var(--end-color);
    filter: drop-shadow(0 0 4px var(--end-glow));
}

.legend-marker.legend-path {
    width: 24px;
    height: 6px;
    background: var(--route-color);
    border-radius: var(--radius-full);
    animation: pathPulse 2s ease-in-out infinite;
}

.legend-marker.legend-building {
    width: 20px;
    height: 20px;
    background: var(--building-color);
    border-radius: var(--radius-sm);
    box-shadow: 0 0 8px var(--building-glow);
}

@keyframes pathPulse {

    0%,
    100% {
        opacity: 1;
        box-shadow: 0 0 8px var(--route-glow);
    }

    50% {
        opacity: 0.7;
        box-shadow: 0 0 15px var(--route-glow);
    }
}

/* Quick Tips Section */
.quick-tips {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.quick-tips-title {
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.quick-tips-list {
    display: flex;
    gap: var(--space-md);
    list-style: none;
}

.quick-tips-list li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
    white-space: nowrap;
}

.quick-tips-list li::before {
    content: '→';
    color: var(--primary);
    font-weight: bold;
}

/* ===== MAP ELEMENTS STYLING ===== */
.cls-5,
.cls-6,
.cls-4 {
    cursor: pointer;
    transition: var(--transition-base);
}

.cls-5:hover,
.cls-6:hover,
.cls-4:hover {
    filter: brightness(1.2) drop-shadow(0 0 10px var(--building-glow));
}

.building-active {
    filter: brightness(1.3) drop-shadow(0 0 15px var(--building-glow)) !important;
    animation: buildingGlow 1.5s ease-in-out infinite;
}

.building-start {
    stroke: var(--start-color) !important;
    stroke-width: 20px;
    stroke-opacity: 1;
    filter: drop-shadow(0 0 20px var(--start-glow)) !important;
    animation: blinkBorder 1s ease-in-out infinite !important;
}

.building-end {
    stroke: var(--end-color) !important;
    stroke-width: 20px;
    stroke-opacity: 1;
    filter: drop-shadow(0 0 20px var(--end-glow)) !important;
    animation: blinkBorder 1s ease-in-out infinite !important;
}

@keyframes blinkBorder {

    0%,
    100% {
        stroke-opacity: 1;
        stroke-width: 20px;
    }

    50% {
        stroke-opacity: 0;
        stroke-width: 20px;
    }
}

@keyframes buildingGlow {

    0%,
    100% {
        filter: brightness(1.3) drop-shadow(0 0 15px var(--building-glow));
    }

    50% {
        filter: brightness(1.5) drop-shadow(0 0 25px var(--building-glow));
    }
}

/* Route path - RED */
.path-active {
    fill: var(--route-color) !important;
    animation: pathFlow 0.5s ease-out forwards, routeGlow 2s ease-in-out infinite;
}

@keyframes pathFlow {
    from {
        opacity: 0;
        fill: transparent;
    }

    to {
        opacity: 1;
        fill: var(--route-color);
    }
}

@keyframes routeGlow {

    0%,
    100% {
        filter: brightness(1) drop-shadow(0 0 8px var(--route-glow));
    }

    50% {
        filter: brightness(1.3) drop-shadow(0 0 15px var(--route-glow));
    }
}

/* Map markers - LARGER SIZE */
.map-marker {
    animation: markerBounce 0.5s ease-out;
    filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.4));
}

@keyframes markerBounce {
    0% {
        transform: translateY(-50px) scale(0);
        opacity: 0;
    }

    60% {
        transform: translateY(10px) scale(1.1);
    }

    100% {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
}

/* Building text labels - clickable but NO hover effects */
/* Cursor is set via JavaScript */

/* ===== GALLERY MODAL - Redesigned with Centered Content ===== */
.gallery-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-base);
}

.gallery-modal.active {
    opacity: 1;
    visibility: visible;
}

.gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
}

.gallery-container {
    position: relative;
    width: 90%;
    max-width: 900px;
    max-height: 85vh;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    transform: translateY(20px) scale(0.95);
    transition: var(--transition-base);
    overflow: hidden;
}

.gallery-modal.active .gallery-container {
    transform: translateY(0) scale(1);
}

.gallery-header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--border-subtle);
    position: relative;
}

.gallery-title-wrapper {
    flex: 1;
    text-align: center;
}

.gallery-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin: 0;
}

.gallery-close {
    position: absolute;
    right: var(--space-lg);
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border: 1px solid var(--border-color);
    background: var(--surface-1);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
}

.gallery-close svg {
    width: 20px;
    height: 20px;
}

.gallery-close:hover {
    background: var(--danger);
    color: white;
    border-color: var(--danger);
}

.gallery-body {
    padding: var(--space-xl);
    overflow-y: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-lg);
    width: 100%;
    justify-items: center;
}

.gallery-image-wrapper {
    aspect-ratio: 4/3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-tertiary);
    position: relative;
    animation: fadeInUp 0.5s ease-out backwards;
    border: 1px solid var(--border-subtle);
    width: 100%;
    max-width: 280px;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.gallery-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-base);
}

.gallery-image-wrapper:hover img {
    transform: scale(1.1);
}

.gallery-image-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-sm) var(--space-md);
    background: linear-gradient(to top, hsla(0, 0%, 0%, 0.8), transparent);
    color: white;
    font-size: var(--font-size-xs);
    font-weight: 500;
}

.gallery-empty {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
    color: var(--text-muted);
    text-align: center;
}

.gallery-empty svg {
    width: 64px;
    height: 64px;
    margin-bottom: var(--space-md);
    opacity: 0.5;
}

/* ===== GALLERY LOADING CONTAINER - Centralized Spinner ===== */
.gallery-loading-container {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl) var(--space-2xl);
    gap: var(--space-lg);
    min-height: 250px;
}

.gallery-loading-container.visible {
    display: flex;
}

.gallery-spinner {
    position: relative;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.spinner-ring {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 3px solid transparent;
    animation: spinnerRotate 1.5s linear infinite;
}

.spinner-ring:nth-child(1) {
    border-top-color: var(--primary);
    animation-duration: 1.5s;
}

.spinner-ring:nth-child(2) {
    width: 70%;
    height: 70%;
    border-right-color: var(--accent-teal);
    animation-duration: 1.2s;
    animation-direction: reverse;
}

.spinner-ring:nth-child(3) {
    width: 40%;
    height: 40%;
    border-bottom-color: var(--accent-cyan);
    animation-duration: 0.9s;
}

.spinner-icon {
    width: 28px;
    height: 28px;
    color: var(--primary);
    animation: pulseGlow 1.5s ease-in-out infinite;
}

@keyframes spinnerRotate {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}

@keyframes pulseGlow {

    0%,
    100% {
        opacity: 0.6;
        filter: drop-shadow(0 0 4px var(--primary-glow));
    }

    50% {
        opacity: 1;
        filter: drop-shadow(0 0 12px var(--primary-glow));
    }
}

.loading-text {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    font-weight: 500;
}

.loading-dots::after {
    content: '';
    animation: loadingDots 1.5s infinite;
}

@keyframes loadingDots {
    0% {
        content: '';
    }

    25% {
        content: '.';
    }

    50% {
        content: '..';
    }

    75% {
        content: '...';
    }

    100% {
        content: '';
    }
}

/* ===== CLICKABLE GALLERY IMAGES ===== */
.gallery-image-wrapper {
    cursor: pointer;
    position: relative;
    overflow: hidden;
}

.gallery-image-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
            rgba(52, 152, 219, 0) 0%,
            rgba(52, 152, 219, 0.1) 50%,
            rgba(52, 152, 219, 0) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
    pointer-events: none;
}

.gallery-image-wrapper::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 50px;
    height: 50px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 2;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

.gallery-image-wrapper:hover::before {
    opacity: 1;
}

.gallery-image-wrapper:hover::after {
    transform: translate(-50%, -50%) scale(1);
}

/* Magnifying glass icon on hover */
.gallery-image-wrapper .zoom-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 24px;
    transform: translate(-50%, -50%) scale(0);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 3;
    color: var(--primary);
    pointer-events: none;
}

.gallery-image-wrapper:hover .zoom-icon {
    transform: translate(-50%, -50%) scale(1);
    transition-delay: 0.1s;
}

/* ===== FULL-SCREEN IMAGE VIEWER MODAL ===== */
.image-viewer-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
}

.image-viewer-modal.active {
    opacity: 1;
    visibility: visible;
}

.image-viewer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
}

/* Viewer Controls Bar */
.image-viewer-controls {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-xl);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.viewer-info {
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.viewer-counter {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.1);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-weight: 500;
}

.viewer-title {
    font-size: var(--font-size-base);
    color: white;
    font-weight: 500;
}

.viewer-zoom-controls {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
}

.viewer-btn {
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
}

.viewer-btn svg {
    width: 20px;
    height: 20px;
}

.viewer-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
    transform: scale(1.05);
}

.viewer-btn:active {
    transform: scale(0.95);
}

.viewer-close-btn:hover {
    background: var(--danger);
    border-color: var(--danger);
}

.viewer-zoom-level {
    min-width: 60px;
    text-align: center;
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    font-family: 'Courier New', monospace;
}

.viewer-divider {
    width: 1px;
    height: 24px;
    background: rgba(255, 255, 255, 0.2);
    margin: 0 var(--space-xs);
}

/* Navigation Arrows */
.viewer-nav-btn {
    position: absolute;
    top: 50%;
    z-index: 10;
    width: 56px;
    height: 56px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 50%;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateY(-50%);
    transition: all 0.3s ease;
    opacity: 0.7;
}

.viewer-nav-btn svg {
    width: 28px;
    height: 28px;
}

.viewer-nav-btn:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-50%) scale(1.1);
}

.viewer-prev {
    left: var(--space-xl);
}

.viewer-next {
    right: var(--space-xl);
}

.viewer-nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
}

.viewer-nav-btn:disabled:hover {
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
}

/* Image Container */
.image-viewer-container {
    position: relative;
    z-index: 5;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    cursor: grab;
    padding: var(--space-xl);
}

.image-viewer-container.grabbing {
    cursor: grabbing;
}

.viewer-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.15s ease-out;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    user-select: none;
}

/* Image Loading State */
.viewer-image.loading {
    opacity: 0;
}

.image-viewer-container::before {
    content: '';
    position: absolute;
    width: 50px;
    height: 50px;
    border: 3px solid rgba(255, 255, 255, 0.1);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spinnerRotate 1s linear infinite;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}

.image-viewer-container.image-loading::before {
    opacity: 1;
}

/* Thumbnail Strip */
.viewer-thumbnails {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    overflow-x: auto;
    scrollbar-width: none;
}

.viewer-thumbnails::-webkit-scrollbar {
    display: none;
}

.viewer-thumbnail {
    width: 60px;
    height: 45px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    opacity: 0.6;
    transition: all 0.2s ease;
    flex-shrink: 0;
}

.viewer-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.viewer-thumbnail:hover {
    opacity: 0.9;
    border-color: rgba(255, 255, 255, 0.3);
    transform: scale(1.05);
}

.viewer-thumbnail.active {
    opacity: 1;
    border-color: var(--primary);
    box-shadow: 0 0 15px var(--primary-glow);
}

/* ===== RESPONSIVE IMAGE VIEWER ===== */
@media (max-width: 768px) {
    .image-viewer-controls {
        padding: var(--space-sm) var(--space-md);
        flex-wrap: wrap;
        gap: var(--space-sm);
    }

    .viewer-info {
        width: 100%;
        justify-content: center;
    }

    .viewer-zoom-controls {
        width: 100%;
        justify-content: center;
    }

    .viewer-btn {
        width: 36px;
        height: 36px;
    }

    .viewer-btn svg {
        width: 18px;
        height: 18px;
    }

    .viewer-nav-btn {
        width: 44px;
        height: 44px;
    }

    .viewer-nav-btn svg {
        width: 22px;
        height: 22px;
    }

    .viewer-prev {
        left: var(--space-sm);
    }

    .viewer-next {
        right: var(--space-sm);
    }

    .viewer-thumbnail {
        width: 50px;
        height: 38px;
    }
}

/* ===== HELP MODAL ===== */
.help-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-base);
}

.help-modal.active {
    opacity: 1;
    visibility: visible;
}

.help-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
}

.help-container {
    position: relative;
    width: 90%;
    max-width: 600px;
    max-height: 85vh;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    transform: translateY(20px) scale(0.95);
    transition: var(--transition-base);
    overflow: hidden;
}

.help-modal.active .help-container {
    transform: translateY(0) scale(1);
}

.help-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--border-subtle);
}

.help-header h2 {
    font-size: var(--font-size-lg);
    font-weight: 600;
}

.help-close {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border-color);
    background: var(--surface-1);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
}

.help-close svg {
    width: 20px;
    height: 20px;
}

.help-close:hover {
    background: var(--danger);
    color: white;
    border-color: var(--danger);
}

.help-body {
    padding: var(--space-xl);
    overflow-y: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    scrollbar-width: thin;
    scrollbar-color: var(--text-muted) transparent;
}

.help-body::-webkit-scrollbar {
    width: 6px;
}

.help-body::-webkit-scrollbar-track {
    background: transparent;
    border-radius: 3px;
}

.help-body::-webkit-scrollbar-thumb {
    background: var(--text-muted);
    border-radius: 3px;
}

.help-body::-webkit-scrollbar-thumb:hover {
    background: var(--primary);
}

.help-section h3 {
    font-size: var(--font-size-base);
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
}

.help-section p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    line-height: 1.7;
}

.help-section ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
}

.help-section li {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    padding-left: var(--space-md);
    position: relative;
}

.help-section li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--primary);
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 1200px) {
    .top-control-bar {
        max-width: 95%;
        padding: 4px 6px;
    }

    .location-selector-btn {
        min-width: 130px;
        padding: var(--space-xs) var(--space-sm);
    }
}

@media (max-width: 1099px) {
    .top-control-bar {
        /* Keep as single row, don't wrap */
        gap: 4px;
        padding: 6px 8px;
    }

    .logo {
        /* Keep compact, don't take full width */
        padding-right: var(--space-sm);
        margin-right: var(--space-xs);
    }

    /* Stack FUTIA and Campus Navigator vertically to save horizontal space */
    .logo-text {
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
    }

    .brand-futia {
        font-size: var(--font-size-sm);
        line-height: 1.2;
    }

    .brand-campus {
        font-size: var(--font-size-xs);
        line-height: 1.2;
    }

    /* Make selectors more compact */
    .location-selector-btn {
        min-width: 110px;
        padding: 6px 10px;
    }

    /* Theme and Help buttons are moved to zoom controls via JavaScript */
}

/* At 845px Ask FUTIAN moves to bottom bar, so we have more space - show button text */
@media (max-width: 845px) {
    .top-control-bar {
        gap: 6px;
    }

    /* Show full text for Show Route and Clear buttons since Ask FUTIAN is in bottom bar */
    .control-btn span {
        display: inline;
    }

    .control-btn {
        padding: 6px 12px;
    }

    /* Make location selectors use available space */
    .location-selector-btn {
        min-width: 120px;
        flex: 1;
    }
}

/* At 769px, hide Clear button text (show only icon) - just before 768px title bar resize */
@media (max-width: 769px) {
    #reset-btn span {
        display: none;
    }

    #reset-btn {
        padding: 6px;
        min-width: auto;
    }
}

/* At 616px, hide Show Route button (auto-route takes over) and show Clear with full text */
@media (max-width: 616px) {

    /* Hide Show Route button - route will auto-show when both locations selected */
    #go-btn {
        display: none;
    }

    /* Show Clear button with full text now that we have space */
    #reset-btn span {
        display: inline;
    }

    #reset-btn {
        padding: 6px 12px;
        min-width: auto;
    }
}

/* At 529px, Clear button shows only icon */
@media (max-width: 529px) {
    #reset-btn span {
        display: none;
    }

    #reset-btn {
        padding: 6px;
    }
}

@media (max-width: 480px) {
    .top-control-bar {
        gap: 4px;
    }

    .logo {
        padding-bottom: 2px;
        margin-bottom: 2px;
    }

    .logo-text {
        display: none;
    }

    /* On very small screens, make location selectors stack or become very minimal */
    .location-selector-btn {
        padding: 4px 8px;
    }

    .location-selector-btn span {
        max-width: 80px;
    }

    .gallery-container,
    .help-container {
        width: 95%;
        max-height: 90vh;
        border-radius: var(--radius-lg);
    }

    .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-sm);
    }
}

/* ===== NAVIGATE BUTTON (hidden by default, shown at 409px) ===== */
.navigate-btn {
    display: none;
    background: var(--surface-glass);
    backdrop-filter: blur(5px);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
}

.navigate-btn:hover {
    background: var(--surface-2);
    filter: brightness(1.05);
    transform: scale(1.02);
}

/* ===== ROUTE SELECTION MODAL ===== */
.route-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: var(--space-md);
}

.route-modal.active {
    display: flex;
}

.route-modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
}

.route-modal-container {
    position: relative;
    background: var(--surface-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    width: 100%;
    max-width: 340px;
    box-shadow: var(--shadow-lg), 0 0 40px rgba(52, 152, 219, 0.2);
    animation: modalSlideIn 0.3s ease-out;
    overflow: hidden;
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: scale(0.9) translateY(20px);
    }

    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.route-modal-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: linear-gradient(135deg, rgba(52, 152, 219, 0.2), rgba(155, 89, 182, 0.1));
    border-bottom: 1px solid var(--border-subtle);
}

.route-modal-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

.route-modal-icon svg {
    width: 20px;
    height: 20px;
}

.route-modal-header h2 {
    flex: 1;
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
}

.route-modal-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    position: relative;
}

.route-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
}

.route-field-label {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    font-weight: 500;
}

.route-field-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.route-field-icon svg {
    width: 16px;
    height: 16px;
}

.route-field-icon.start {
    color: #ff9500;
}

.route-field-icon.end {
    color: #ffd700;
}

.route-select-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    background: var(--surface-1);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    color: var(--text-primary);
    font-size: var(--font-size-base);
    cursor: pointer;
    transition: var(--transition-base);
}

.route-select-btn:hover {
    background: var(--surface-2);
    border-color: var(--primary);
}

.route-select-btn.selected {
    border-color: var(--primary);
    background: rgba(52, 152, 219, 0.1);
}

.route-select-btn .chevron {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    transition: transform 0.2s;
}

.route-swap-btn {
    align-self: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface-1);
    border: 2px dashed var(--border-medium);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
    margin: var(--space-xs) 0;
}

.route-swap-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: rotate(180deg);
}

.route-swap-btn svg {
    width: 18px;
    height: 18px;
}

.route-modal-footer {
    padding: var(--space-md);
    border-top: 1px solid var(--border-subtle);
    display: flex;
    gap: var(--space-sm);
}

.route-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-base);
    white-space: nowrap;
}

.route-btn.primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    border-color: var(--primary);
    box-shadow: var(--shadow-md), 0 0 20px var(--primary-glow);
}

.route-btn.secondary {
    background: var(--surface-glass);
    backdrop-filter: blur(5px);
    color: var(--text-secondary);
}

.route-btn:hover {
    transform: translateY(-1px);
}

.route-btn.primary:hover {
    filter: brightness(1.15);
    box-shadow: var(--shadow-lg), 0 0 30px var(--primary-glow);
}

.route-btn.secondary:hover {
    background: var(--surface-2);
    color: var(--text-primary);
    filter: brightness(1.1);
}

.route-btn svg {
    width: 18px;
    height: 18px;
}

.route-btn.incomplete {
    opacity: 0.6;
}

/* ===== 409px BREAKPOINT - Very small screens ===== */
@media (max-width: 409px) {

    /* Hide location selectors and swap button in top bar */
    .location-selector-btn,
    .swap-btn,
    #go-btn {
        display: none !important;
    }

    /* Show Get Direction button - position it after logo (left side) */
    .navigate-btn {
        display: flex;
        order: 1;
    }

    /* Position Clear button on the right */
    #reset-btn {
        order: 10;
        margin-left: auto;
        padding: 6px 12px;
    }

    /* Show Clear button with full text */
    #reset-btn span {
        display: inline;
    }

    /* Adjust top bar for compact layout */
    .top-control-bar {
        gap: 6px;
    }

    /* Logo stays first */
    .logo {
        order: 0;
    }
}

/* ===== 311px BREAKPOINT - Ultra small screens ===== */
@media (max-width: 311px) {

    /* Hide Clear button text when space is extremely limited */
    #reset-btn span {
        display: none;
    }

    #reset-btn {
        padding: 6px;
    }
}

/* ===== 295px BREAKPOINT - Route Modal Clear Icon Only ===== */
@media (max-width: 295px) {
    #route-modal-clear span {
        display: none;
    }

    #route-modal-clear {
        flex: 0 0 auto;
        padding: var(--space-sm);
        width: 44px;
        justify-content: center;
    }
}

/* ===== 255px BREAKPOINT - Hide Top Bar Clear Icon ===== */
@media (max-width: 255px) {
    #reset-btn {
        display: none !important;
    }
}

/* ===== 209px BREAKPOINT - Minimal UI ===== */
@media (max-width: 209px) {

    /* Get Direction button shows only icon */
    .navigate-btn span {
        display: none;
    }

    .navigate-btn {
        padding: 6px;
        min-width: auto;
    }

    /* Hide Ask FUTIAN button in bottom bar completely */
    .mobile-bottom-bar #ask-futian-btn {
        display: none;
    }
}

/* ===== ACCESSIBILITY ===== */
@media (prefers-reduced-motion: reduce) {

    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}

/* Focus states for keyboard navigation */
button:focus-visible,
select:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
}

/* ===== SCROLLBAR STYLING ===== */
::-webkit-scrollbar {
    width: 6px;
    height: 6px;
}

::-webkit-scrollbar-track {
    background: var(--bg-tertiary);
    border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb {
    background: var(--text-muted);
    border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb:hover {
    background: var(--primary);
}

/* Dark mode scrollbar */
body.dark-mode ::-webkit-scrollbar-track {
    background: #1e1e1e;
}

body.dark-mode ::-webkit-scrollbar-thumb {
    background-color: #555;
}

body.dark-mode ::-webkit-scrollbar-thumb:hover {
    background-color: #777;
}

/* Custom Toast Notification */
.custom-toast {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(-100%);
    background: rgba(20, 20, 30, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 12px 24px;
    border-radius: 50px;
    color: white;
    font-family: 'Inter', sans-serif;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 9999;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
}

.custom-toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
}

.custom-toast svg {
    width: 20px;
    height: 20px;
}

.custom-toast.warning {
    border-color: rgba(255, 200, 0, 0.5);
    color: #FFD700;
}

.custom-toast.error {
    border-color: rgba(255, 50, 50, 0.5);
    color: #FF4444;
}

/* Building hover effect */
.building-hover-active {
    filter: brightness(1.3) drop-shadow(0 0 15px rgba(255, 215, 0, 0.6)) !important;
    transition: filter 0.2s ease;
    stroke: gold !important;
    stroke-width: 2px !important;
}

/* ===== ALL BUILDINGS MODAL ===== */
.all-buildings-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-base);
}

.all-buildings-modal.active {
    opacity: 1;
    visibility: visible;
}

.all-buildings-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
}

.all-buildings-container {
    position: relative;
    width: 95%;
    max-width: 1100px;
    max-height: 90vh;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg), 0 0 60px rgba(52, 152, 219, 0.15);
    display: flex;
    flex-direction: column;
    transform: translateY(30px) scale(0.95);
    transition: var(--transition-base);
    overflow: hidden;
}

.all-buildings-modal.active .all-buildings-container {
    transform: translateY(0) scale(1);
}

.all-buildings-header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--border-subtle);
    position: relative;
    background: linear-gradient(180deg, rgba(52, 152, 219, 0.08) 0%, transparent 100%);
}

.all-buildings-title-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.all-buildings-icon {
    width: 28px;
    height: 28px;
    color: var(--primary);
    filter: drop-shadow(0 0 6px var(--primary-glow));
}

.all-buildings-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin: 0;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.all-buildings-close {
    position: absolute;
    right: var(--space-lg);
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border: 1px solid var(--border-color);
    background: var(--surface-1);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-base);
}

.all-buildings-close svg {
    width: 20px;
    height: 20px;
}

.all-buildings-close:hover {
    background: var(--danger);
    color: white;
    border-color: var(--danger);
    transform: translateY(-50%) scale(1.05);
}

.all-buildings-body {
    padding: var(--space-xl);
    overflow-y: auto;
    flex: 1;
}

/* Loading state */
.all-buildings-loading {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl) var(--space-2xl);
    gap: var(--space-lg);
    min-height: 300px;
}

.all-buildings-loading.visible {
    display: flex;
}

/* Buildings Grid */
.all-buildings-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    width: 100%;
}

/* Building Card */
.building-card {
    position: relative;
    aspect-ratio: 16/11;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    animation: cardFadeIn 0.5s ease-out backwards;
}

@keyframes cardFadeIn {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.95);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.building-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 12px 40px rgba(52, 152, 219, 0.25),
        0 0 30px rgba(52, 152, 219, 0.15);
    border-color: var(--primary);
}

.building-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.building-card:hover .building-card-image {
    transform: scale(1.1);
}

/* Building card overlay */
.building-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
            transparent 0%,
            transparent 40%,
            rgba(0, 0, 0, 0.7) 80%,
            rgba(0, 0, 0, 0.9) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-md);
    transition: background 0.3s ease;
}

.building-card:hover .building-card-overlay {
    background: linear-gradient(180deg,
            rgba(52, 152, 219, 0.1) 0%,
            rgba(0, 0, 0, 0.5) 40%,
            rgba(0, 0, 0, 0.85) 100%);
}

.building-card-name {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: white;
    margin: 0;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease;
}

.building-card:hover .building-card-name {
    transform: translateY(-2px);
}

.building-card-count {
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.7);
    margin-top: var(--space-xs);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
}

.building-card-count svg {
    width: 14px;
    height: 14px;
    opacity: 0.8;
}

/* No image placeholder */
.building-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-tertiary) 0%, var(--surface-1) 100%);
    color: var(--text-muted);
    gap: var(--space-sm);
}

.building-card-placeholder svg {
    width: 40px;
    height: 40px;
    opacity: 0.4;
}

/* View images badge on hover */
.building-card-badge {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--primary);
    border-radius: var(--radius-pill);
    font-size: 10px;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(52, 152, 219, 0.4);
}

.building-card:hover .building-card-badge {
    opacity: 1;
    transform: translateY(0);
}

/* ===== RESPONSIVE ALL BUILDINGS MODAL ===== */
@media (max-width: 1024px) {
    .all-buildings-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 768px) {
    .all-buildings-container {
        width: 95%;
        max-height: 85vh;
    }

    .all-buildings-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-md);
    }

    .all-buildings-body {
        padding: var(--space-md);
    }

    .all-buildings-header {
        padding: var(--space-md) var(--space-lg);
    }

    .all-buildings-title {
        font-size: var(--font-size-lg);
    }

    .all-buildings-icon {
        width: 24px;
        height: 24px;
    }
}

@media (max-width: 480px) {
    .all-buildings-container {
        width: 98%;
        max-height: 90vh;
        border-radius: var(--radius-lg);
    }

    .all-buildings-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-sm);
    }

    .building-card {
        aspect-ratio: 4/3;
    }

    .building-card-name {
        font-size: var(--font-size-xs);
    }

    .building-card-overlay {
        padding: var(--space-sm);
    }

    .all-buildings-close {
        width: 36px;
        height: 36px;
        right: var(--space-md);
    }

    .all-buildings-close svg {
        width: 18px;
        height: 18px;
    }
}

/* ===== DOUBLE-TAP ZOOM RIPPLE EFFECT ===== */
.double-tap-ripple {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 100px;
    height: 100px;
    margin-left: -50px;
    margin-top: -50px;
    border-radius: 50%;
    border: 3px solid var(--primary);
    background: radial-gradient(circle, rgba(52, 152, 219, 0.3) 0%, transparent 70%);
    animation: doubleTapRipple 0.4s ease-out forwards;
    box-shadow:
        0 0 20px var(--primary-glow),
        inset 0 0 20px rgba(52, 152, 219, 0.15);
}

@keyframes doubleTapRipple {
    0% {
        transform: scale(0.3);
        opacity: 1;
        border-width: 4px;
    }

    50% {
        border-width: 2px;
    }

    100% {
        transform: scale(1.5);
        opacity: 0;
        border-width: 1px;
    }
}

/* Dark mode ripple adjustment */
body.dark-mode .double-tap-ripple {
    border-color: var(--primary-light);
    background: radial-gradient(circle, rgba(93, 173, 226, 0.35) 0%, transparent 70%);
    box-shadow:
        0 0 25px rgba(93, 173, 226, 0.5),
        inset 0 0 20px rgba(93, 173, 226, 0.2);
}

/* Zoom level indicator inside ripple */
.ripple-zoom-level {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 18px;
    font-weight: 700;
    color: var(--primary);
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
    animation: zoomLevelPop 0.4s ease-out forwards;
    white-space: nowrap;
}

@keyframes zoomLevelPop {
    0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.5);
    }

    30% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1.2);
    }

    100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(1);
    }
}

body.dark-mode .ripple-zoom-level {
    color: var(--primary-light);
    text-shadow: 0 0 15px rgba(0, 0, 0, 0.8);
}